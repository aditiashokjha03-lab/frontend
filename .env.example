# Frontend Environment Variables (Vite — available in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side Environment Variables (Netlify Functions — NOT exposed to browser)
# These MUST be set in Netlify Dashboard > Site settings > Environment variables
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
